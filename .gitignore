# This .gitignore file ensures that large, auto-generated Unity folders 
# (like Library and Temp) are not tracked by Git.

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Vv]r/

# Asset meta discard files
/[Aa]ssets/AssetStoreTools*

# Autogenerated VS/VS Code project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.tlog

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.unitypackage

# Crashlytics
crashlytics-build.properties

# OS generated files
.DS_Store
Thumbs.db
